# Copy this file to .env.local and fill in YOUR_PC_LAN_IP
# (find it with `ipconfig` on Windows or `ifconfig`/`ip addr` on Mac/Linux)
#
# This lets your phone — on the same WiFi as your PC — reach the Flask
# backend running on your PC, instead of trying (and failing) to reach
# "localhost" on the phone itself.

NEXT_PUBLIC_API_BASE=http://YOUR_PC_LAN_IP:5050
